# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# IP address or hostname of the Windows machine with Cities: Skylines installed.
CITIES_HOST=192.168.1.x

# SMB share name for the Cities: Skylines install folder.
# The game folder must be shared from Windows (e.g. right-click → Share).
CITIES_GAME_SHARE=Cities_Skylines

# SMB share name for the Windows user's AppData\Local folder.
# Share: C:\Users\<YourName>\AppData\Local\Colossal Order\Cities_Skylines
# Tip: share the whole Local folder and set CITIES_DATA_SHARE to the sub-path below it.
# NOTE: values with spaces do NOT need quotes — the parser handles them automatically.
CITIES_DATA_SHARE=Users/YourName/AppData/Local/Colossal Order/Cities_Skylines

# SMB username that has access to both shares.
CITIES_SMB_USER=YourShareUser

# SMB password — leave blank to be prompted at runtime.
# You can also set this in your shell profile (export SMB_PASSWORD=...) to avoid prompts.
SMB_PASSWORD=

# Optional: override the local Linux mount points (defaults shown below).
# CITIES_GAME_MOUNT=/mnt/cities_skylines
# CITIES_DATA_MOUNT=/mnt/cities_skylines_data
